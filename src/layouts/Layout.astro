---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Clôture Pro Laval | Fence Installation Montreal, Laval & Area | Pool Fence Experts',
  description = 'Clôture Pro Laval — Professional fence installation in Montreal, Laval, Longueuil & Greater Montreal. Wood fence, vinyl fence, aluminum fence, pool fence & chain-link. Free estimates.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="fence installation Montreal, fence installation Laval, pool fence Montreal, clôture piscine Laval, wood fence Montreal, vinyl fence Laval, aluminum fence Montreal, chain link fence Laval, fence contractor Montreal, cloture installation Laval, pose de cloture Montreal, installateur de clôture Laval, clôture de piscine Montreal, North Shore fence, South Shore fence" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://www.cloturepro.ca/" />
  <meta property="og:title" content="Clôture Pro Laval | Fence Installation Montreal & Laval" />
  <meta property="og:description" content="Expert fence installation in Montreal, Laval & Greater Montreal. Wood, vinyl, aluminum, pool fence & chain-link. Free estimates!" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://www.cloturepro.ca/" />
  <meta property="og:image" content="/images/logo.png" />
  <meta property="og:locale" content="en_CA" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Clôture Pro Laval",
    "description": "Professional fence installation company serving Montreal, Laval and Greater Montreal.",
    "url": "https://www.cloturepro.ca",
    "logo": "https://www.cloturepro.ca/images/logo.png",
    "telephone": "+1-514-000-0000",
    "email": "info@cloturepro.ca",
    "address": { "@type": "PostalAddress", "addressLocality": "Laval", "addressRegion": "QC", "addressCountry": "CA" },
    "areaServed": ["Laval","Montreal","Longueuil","Brossard","Saint-Laurent","Repentigny","Terrebonne","Blainville","Boisbriand","Sainte-Thérèse","Dollard-des-Ormeaux","Pointe-Claire","LaSalle","Verdun","Saint-Léonard","Anjou","Rivière-des-Prairies"],
    "openingHours": "Mo-Sa 07:00-19:00",
    "priceRange": "$$"
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <slot />
  <script is:inline src="/scripts/main.js"></script>
</body>
</html>
