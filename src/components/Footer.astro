---
const { BASE_URL } = import.meta.env;
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src={`${BASE_URL}images/logo.png`} alt="Clôture Pro Laval - Fence Installation" class="footer-logo" />
        <p data-i18n="ft.brand.p">Professional fence installation across Montreal, Laval and Greater Montreal. Quality workmanship, premium materials, exceptional service.</p>
        <div class="footer-social">
          <a href="#" aria-label="Facebook">&#128268;</a>
          <a href="#" aria-label="Instagram">&#128247;</a>
        </div>
      </div>

      <div class="footer-col">
        <h4 data-i18n="ft.svc.h4">Services</h4>
        <ul>
          <li><a href="#services" data-i18n="ft.svc1">Wood Fence Installation</a></li>
          <li><a href="#services" data-i18n="ft.svc2">Pool Fence Installation</a></li>
          <li><a href="#services" data-i18n="ft.svc3">Vinyl Fence Installation</a></li>
          <li><a href="#services" data-i18n="ft.svc4">Aluminum Fence Installation</a></li>
          <li><a href="#services" data-i18n="ft.svc5">Chain-Link Fence</a></li>
          <li><a href="#services" data-i18n="ft.svc6">Fence Repair</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 data-i18n="ft.area.h4">Service Areas</h4>
        <ul>
          <li><a href="#service-area" data-i18n="ft.area1">Fence Installation Laval</a></li>
          <li><a href="#service-area" data-i18n="ft.area2">Fence Installation Montreal</a></li>
          <li><a href="#service-area" data-i18n="ft.area3">Fence Installation Brossard</a></li>
          <li><a href="#service-area" data-i18n="ft.area4">Fence Installation Longueuil</a></li>
          <li><a href="#service-area" data-i18n="ft.area5">Fence Installation Repentigny</a></li>
          <li><a href="#service-area" data-i18n="ft.area6">Fence Installation Terrebonne</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 data-i18n="ft.contact.h4">Contact</h4>
        <ul class="footer-contact">
          <li><a href="tel:+15140000000">&#128222; (514) 000-0000</a></li>
          <li><a href="mailto:info@cloturepro.ca">&#9993; info@cloturepro.ca</a></li>
          <li data-i18n="ft.hours">&#128336; Mon–Sat: 7AM – 7PM</li>
          <li>&#128205; Montreal, Laval &amp; Area</li>
        </ul>
        <a href="#contact" class="btn btn-primary btn-sm" style="margin-top:1rem;" data-i18n="ft.quote">Free Quote</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p data-i18n="ft.bottom">&copy; 2025 Clôture Pro Laval — Fence Installation Montreal &amp; Laval. All rights reserved.</p>
      <p class="footer-seo-text">Serving: Montreal · Laval · Brossard · Longueuil · Repentigny · Terrebonne · Blainville · Saint-Laurent · Dollard-des-Ormeaux · Pointe-Claire · LaSalle · Verdun · Anjou · Saint-Léonard · Kirkland · Beaconsfield · Rivière-des-Prairies · Boisbriand · Sainte-Thérèse · Rosemère · Mascouche · Saint-Eustache · Varennes · Boucherville · Candiac · La Prairie · Châteauguay</p>
    </div>
  </div>
</footer>

<a href="#contact" class="floating-cta" data-i18n="cta.float">Get Free Quote</a>
