<section class="trust-bar">
  <div class="container trust-grid">
    <div class="trust-item">
      <span class="trust-num" data-count="500" data-suffix="+">500+</span>
      <span class="trust-label" data-i18n="tr.projects">Projects Completed</span>
    </div>
    <div class="trust-item">
      <span class="trust-num" data-count="10" data-suffix="+">10+</span>
      <span class="trust-label" data-i18n="tr.experience">Years Experience</span>
    </div>
    <div class="trust-item">
      <span class="trust-num" data-count="30" data-suffix="+">30+</span>
      <span class="trust-label" data-i18n="tr.cities">Cities Served</span>
    </div>
    <div class="trust-item">
      <span class="trust-num" data-count="100" data-suffix="%">100%</span>
      <span class="trust-label" data-i18n="tr.guarantee">Satisfaction Guarantee</span>
    </div>
  </div>
</section>
